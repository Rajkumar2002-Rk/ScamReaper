# ScamReaper — .gitignore

# ── Node / JS ─────────────────────────────────────────────
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
.metro-health-check*

# ── Expo ──────────────────────────────────────────────────
.expo/
.expo-shared/
web-build/
dist/
expo-env.d.ts

# ── iOS build artifacts ───────────────────────────────────
ios/build/
ios/Pods/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# ── Android build artifacts ───────────────────────────────
android/build/
android/app/build/
android/.gradle/
android/local.properties

# ── ML training ───────────────────────────────────────────
ml/__pycache__/
ml/.venv/
ml/venv/
ml/env/

# Trained model — regenerate with `python ml/train_model.py`
*.tflite

# ── Python ────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/
.pytest_cache/

# ── Builds / bundles ──────────────────────────────────────
build/
out/
*.app
*.ipa
*.apk
*.aab

# ── Signing / secrets ─────────────────────────────────────
*.pem
*.p8
*.p12
*.key
*.jks
*.keystore
*.mobileprovision
.env
.env.*
.env.*.local

# ── Editor / OS junk ──────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.orig.*
Thumbs.db

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Misc Expo ─────────────────────────────────────────────
app-example
